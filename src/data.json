  "validation_rules": {
    "printer_name": {
      "min_chars": 1,
      "max_chars": 10,
      "allowed": "alphanumeric + underscore"
    },
    "fix_name": {
      "min_chars": 1,
      "max_chars": 25
    },
    "role_id": {
      "min_chars": 1,
      "max_chars": 10
    },
    "departure_airport": {
      "chars": 3,
      "format": "IATA"
    },
    "runway_airport": {
      "chars": 4,
      "format": "ICAO"
    },
    "aircraft_type": {
      "min_chars": 2,
      "max_chars": 4
    },
    "fix_ac_list": {
      "allowed_values": [
        1,
        2,
        3,
        4
      ]
    },
    "default_config": {
      "max_per_file": 1
    },
    "routing_order": "first_match_wins",
    "wildcard": {
      "xml_value": "",
      "note": "Empty string matches all"
    },
    "site_id": {
      "must_match": "PC-RCU name",
      "valid_values": [
        "PCTa",
        "PCTd",
        "PCTe"
      ]
    }
  },
